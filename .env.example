# Copy this file to .env.local and fill in your values
# Get these from your Supabase project: Settings → API
#
# Until these are filled in, the app runs in LOCAL MODE:
#   - No login required
#   - Submissions don't persist across reloads
#   - Photos stored in browser memory only
# Once filled in, the app activates CLOUD MODE with real auth and storage.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
